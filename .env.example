# Sao chép file này thành .env và điền token của bạn vào
DISCORD_TOKEN=your_bot_token_here

# Prefix lệnh (mặc định là !)
PREFIX=!

# Thời gian (giây) bot tự rời voice channel khi không có ai (mặc định 300s = 5 phút)
IDLE_TIMEOUT=300

# Browser để lấy cookies YouTube (chrome | edge | firefox | chromium | brave)
# Để trống để tự động phát hiện. Hoặc đặt cookies.txt vào thư mục BOT/
COOKIE_BROWSER=chrome
